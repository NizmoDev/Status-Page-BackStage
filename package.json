{
  "name": "status-page-backstage",
  "version": "0.1.0",
  "description": "A simple reusable Backstage status page plugin for platform services",
  "author": {
    "name": "NizmoDev",
    "email": "denispodvin62120@gmail.com"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/NizmoDev/Status-Page-BackStage#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/NizmoDev/Status-Page-BackStage.git"
  },
  "bugs": {
    "url": "https://github.com/NizmoDev/Status-Page-BackStage/issues"
  },
  "keywords": [
    "backstage",
    "backstage-plugin",
    "status-page",
    "statuspage",
    "kubernetes",
    "monitoring",
    "incident-management"
  ],
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "statuspage"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "dev",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.0",
    "@backstage/core-plugin-api": "^1.10.0",
    "@backstage/frontend-plugin-api": "^0.17.0",
    "@material-ui/core": "^4.12.2",
    "@material-ui/icons": "^4.9.1",
    "recharts": "^3.8.1"
  },
  "peerDependencies": {
    "@types/react": "^17.0.0 || ^18.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.30.2"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/frontend-defaults": "^0.5.0",
    "@backstage/frontend-dev-utils": "^0.1.0",
    "@backstage/frontend-test-utils": "^0.6.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.2",
    "react-dom": "^18.0.2",
    "react-router-dom": "^6.30.2"
  }
}
